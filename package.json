{
  "name": "gitlo",
  "version": "1.1.1",
  "description": "CLI tool to backup all your GitHub repositories locally",
  "main": "dist/index.js",
  "bin": {
    "gitlo": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "tsc && node --test \"test/**/*.test.js\"",
    "clean": "rm -rf dist node_modules",
    "prepublishOnly": "npm run build",
    "link": "npm run build && npm link",
    "unlink": "npm unlink -g gitlo || true"
  },
  "keywords": [
    "github",
    "backup",
    "cli",
    "git"
  ],
  "author": "Zeeshan Khan <mr.xee.khan@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/dropocol/gitlo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dropocol/gitlo.git"
  },
  "bugs": {
    "url": "https://github.com/dropocol/gitlo/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "ora": "^5.4.1",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}